import { encryptOwners } from './utils/DigixCreator.js';

async function run() {
  try {
    await encryptOwners([
      "50935279754",
      "50935279754"
    ]);

    console.log("✅ Owners encrypted successfully");
  } catch (err) {
    console.log("❌ Error encrypting owners:", err);
  }
}

run();